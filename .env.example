# --- Blockchain (Vite public env) ---
# EVM chain id. Example: BSC Testnet = 97, Ethereum Mainnet = 1
VITE_CHAIN_ID=97

# Public RPC endpoint used by frontend read/write clients
VITE_RPC_URL="https://data-seed-prebsc-1-s1.binance.org:8545/"

# WalletConnect / Reown project id - REQUIRED for mobile wallet QR scan login.
# Get one for free at https://cloud.reown.com (formerly walletconnect.com).
# Without a real id the "Scan with mobile wallet" QR code will not work.
VITE_WALLETCONNECT_PROJECT_ID=""

# Mining contract address (must implement registerMiner()/claimReward())
VITE_MINING_POOL_ADDRESS="0xd666868D6305978E04a0B3a6bFfB63A5BBcFD8F1"
# Backward compatible alias
VITE_MINER_CONTRACT_ADDRESS="0xd666868D6305978E04a0B3a6bFfB63A5BBcFD8F1"

# Swap contract address (must implement swapSuperToUsdt(uint256))
VITE_SWAP_ROUTER_ADDRESS="0x1C094012b17461C26938752549E367011443592f"
# Backward compatible alias
VITE_SWAP_CONTRACT_ADDRESS="0x1C094012b17461C26938752549E367011443592f"

# SUPER token (optional for UI queries)
VITE_SUPER_ADDRESS="0x24cd69bd4C0137aA836dB9935D37EAe701C81139"

# Android app download URL (APK or market link)
VITE_ANDROID_DOWNLOAD_URL="https://example.com/coin-planet-android.apk"

# iOS app download URL (TestFlight or App Store link)
VITE_IOS_DOWNLOAD_URL="https://testflight.apple.com/join/example"

# QR Code images for download page (optional, for better UX)
# Generate these from your EAS Build links or use qr-code generator
VITE_ANDROID_QR_CODE="https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=YOUR_ANDROID_DOWNLOAD_URL"
VITE_IOS_QR_CODE="https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=YOUR_IOS_DOWNLOAD_URL"

# --- Cloudflare Pages deploy (optional local use) ---
# Used by wrangler pages deploy, can also be set in CI secret.
CLOUDFLARE_ACCOUNT_ID=""

# --- Contracts deploy ---
BSC_TESTNET_RPC_URL="https://data-seed-prebsc-1-s1.binance.org:8545/"
DEPLOYER_PRIVATE_KEY="0xYOUR_PRIVATE_KEY"

# --- Backend API ---
VITE_API_BASE_URL="https://coin-planet-api.dappweb.workers.dev"
EXPO_PUBLIC_API_BASE_URL="https://coin-planet-api.dappweb.workers.dev"
EXPO_PUBLIC_CHAIN_ID="97"
EXPO_PUBLIC_RPC_URL="https://data-seed-prebsc-1-s1.binance.org:8545/"
EXPO_PUBLIC_MINING_POOL_ADDRESS="0xd666868D6305978E04a0B3a6bFfB63A5BBcFD8F1"
EXPO_PUBLIC_SWAP_ROUTER_ADDRESS="0x1C094012b17461C26938752549E367011443592f"
EXPO_PUBLIC_WALLET_PRIVATE_KEY="0xYOUR_TEST_PRIVATE_KEY"
