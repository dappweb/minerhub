{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:api": "npm --prefix backend run dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:cf": "npm run build && wrangler pages deploy dist",
    "deploy:api": "npm --prefix backend run deploy",
    "deploy:contracts": "npm --prefix contracts run deploy:bsc",
    "sync-env": "node scripts/sync-env.mjs",
    "sync-env:dry": "node scripts/sync-env.mjs --dry-run",
    "sync-eas-links": "node scripts/sync-eas-links.mjs",
    "generate-qr-codes": "node scripts/generate-qr-codes.mjs",
    "upload-app": "node scripts/upload-app.mjs",
    "cf:bootstrap": "npm --prefix backend run cf:bootstrap",
    "build:cf": "npm run build",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.97.0",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "valtio": "^2.3.1",
    "viem": "^2.37.2",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wrangler": "^4.10.0"
  }
}
