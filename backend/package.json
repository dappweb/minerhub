{
  "name": "coin-planet-backend",
  "version": "1.0.0",
  "description": "Coin Planet backend API - Cloudflare Workers",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "wrangler dev",
    "dev": "wrangler dev",
    "build": "tsc && npm run build:wasm",
    "build:wasm": "echo 'Building WASM...'",
    "deploy": "wrangler deploy",
    "cf:bootstrap": "node ./scripts/bootstrap-cloudflare.mjs",
    "db:migrate": "wrangler d1 execute coin-planet-db --file=./db/schema.sql",
    "db:migrate:local": "wrangler d1 execute coin-planet-db --local --file=./db/schema.sql",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "ethers": "^6.12.0",
    "jose": "^5.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250124.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0",
    "wrangler": "^4.10.0"
  }
}
