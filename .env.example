# --- Blockchain (Vite public env) ---
# EVM chain id. Example: Base Mainnet = 8453, Ethereum Mainnet = 1
VITE_CHAIN_ID=8453

# Public RPC endpoint used by frontend read/write clients
VITE_RPC_URL="https://mainnet.base.org"

# Mining contract address (must implement registerMiner()/claimReward())
VITE_MINING_POOL_ADDRESS="0x0000000000000000000000000000000000000000"
# Backward compatible alias
VITE_MINER_CONTRACT_ADDRESS="0x0000000000000000000000000000000000000000"

# Swap contract address (must implement swapMmToUsdt(uint256))
VITE_SWAP_ROUTER_ADDRESS="0x0000000000000000000000000000000000000000"
# Backward compatible alias
VITE_SWAP_CONTRACT_ADDRESS="0x0000000000000000000000000000000000000000"

# MM token (optional for UI queries)
VITE_MM_ADDRESS="0x0000000000000000000000000000000000000000"

# Android app download URL (APK or market link)
VITE_ANDROID_DOWNLOAD_URL="https://example.com/minerhub-android.apk"

# iOS app download URL (TestFlight or App Store link)
VITE_IOS_DOWNLOAD_URL="https://testflight.apple.com/join/example"

# --- Cloudflare Pages deploy (optional local use) ---
# Used by wrangler pages deploy, can also be set in CI secret.
CLOUDFLARE_ACCOUNT_ID=""

# --- Contracts deploy ---
SEPOLIA_RPC_URL="https://sepolia.infura.io/v3/YOUR_INFURA_KEY"
DEPLOYER_PRIVATE_KEY="0xYOUR_PRIVATE_KEY"

# --- Backend API ---
VITE_API_BASE_URL="https://minerhub-api.your-subdomain.workers.dev"
EXPO_PUBLIC_API_BASE_URL="https://minerhub-api.your-subdomain.workers.dev"