# --- Blockchain (Vite public env) ---
# EVM chain id. Example: Base Mainnet = 8453, Ethereum Mainnet = 1
VITE_CHAIN_ID=8453

# Public RPC endpoint used by frontend read/write clients
VITE_RPC_URL="https://mainnet.base.org"

# Mining contract address (must implement startMining()/claimRewards())
VITE_MINER_CONTRACT_ADDRESS="0x0000000000000000000000000000000000000000"

# Swap contract address (must implement swapMmToUsdt(uint256))
VITE_SWAP_CONTRACT_ADDRESS="0x0000000000000000000000000000000000000000"

# --- Cloudflare Pages deploy (optional local use) ---
# Used by wrangler pages deploy, can also be set in CI secret.
CLOUDFLARE_ACCOUNT_ID=""
