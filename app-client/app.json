{
  "expo": {
    "name": "Coin Planet",
    "slug": "coin-planet-mobile",
    "scheme": "coinplanet",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "ios": {
      "bundleIdentifier": "com.coinplanet.mobile",
      "supportsTablet": true
    },
    "android": {
      "package": "com.coinplanet.mobile"
    },
    "extra": {
      "rpcUrl": "https://mainnet.base.org",
      "chainId": 8453,
      "minerContractAddress": "0x0000000000000000000000000000000000000000",
      "swapContractAddress": "0x0000000000000000000000000000000000000000"
    },
    "plugins": [
      "expo-asset",
      "expo-secure-store"
    ]
  }
}
